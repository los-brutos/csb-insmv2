    "props": {
      "recupPP": "<p>Toutes les 24 h : +1PP</p><p>Par XX heure de sommeil : +1PP</p><p>XX dépend du salaire mensuel (approximatif) du Démon</p><p></p><table><thead><tr><th><p>Somme</p></th><th><p>XX</p></th></tr></thead><tbody><tr><td><p>Moins de 10 000 Francs</p></td><td><p>12</p></td></tr><tr><td><p>Entre 10 000 et 100 000 Francs</p></td><td><p>8</p></td></tr><tr><td><p>Entre 100 000 et A millions de Francs</p></td><td><p>6</p></td></tr><tr><td><p>Entre 1 et 10 millions de Francs</p></td><td><p>4</p></td></tr><tr><td><p>Plus de 10 millions de Francs</p></td><td><p>2</p></td></tr></tbody></table>",
      "intervention": "2",
      "type": "666",
      "grade1Desc": "<p>Ce grade permet à tout Démon qui l’obtient de connaître (au franc près) le salaire mensuel de toute personne qu'il observe.</p>",
      "grade2Desc": "<p>Ce grade accorde à son possesseur le pouvoir de causer des maladies bénignes sur toute créature qu'il touche.</p>",
      "grade3Desc": "<p>Ce grade permet à tout Démon qui l'obtient de connaître à tout moment la somme d'argent dont il dispose (ainsi que les rentrées et les sorties probables). Il est en fait un minitel (3615 code TUNES) à lui tout seul.</p>",
      "grade1Titre": "Chevalier du pourboire",
      "grade2Titre": "Capitaine des pots de vin",
      "grade3Titre": "Baron de la corruption"
    },
